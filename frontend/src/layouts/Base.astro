---
import "../styles/globals.css";
import type { Metro } from "@/lib/metros";
import Nav from "@/components/shell/Nav.astro";
import Toolbar from "@/components/shell/Toolbar.astro";
import Footer from "@/components/shell/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  metro?: Metro; // absent = the national homepage/directory (E2)
}

// Metro pages pass their metro; the national homepage passes none.
const { metro, title, description } = Astro.props;

const resolvedTitle =
  title ??
  (metro
    ? `MetroTrack — ${metro.region} Transit Tracker`
    : "MetroTrack — Civic Transit Accountability");
const resolvedDescription =
  description ??
  (metro
    ? `A neutral, public accountability tracker for ${metro.region} transit: funding, a usage map against population and jobs, hiring, and a job-access score.`
    : "A neutral, public accountability tracker for U.S. transit: funding, a usage map against population and jobs, hiring, and a job-access score. Every figure shows its source.");

const base = metro ? `/${metro.slug}` : "/";
const logoLabel = metro ? `MetroTrack ${metro.name} home` : "MetroTrack home";
const here = Astro.url.pathname.replace(/\/$/, "");

const ogImage = new URL("/og.png", Astro.site).href;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* Pre-paint: apply persisted a11y/theme prefs before first paint (no FOUC).
        Mirrors the data-attr + localStorage contract in shell/Toggles.tsx. */}
    <script is:inline>
      (function () {
        try {
          var d = document.documentElement;
          if (localStorage.getItem("mt-theme") === "light") d.setAttribute("data-theme", "light");
          if (localStorage.getItem("mt-colorblind") === "on") d.setAttribute("data-colorblind", "on");
          if (localStorage.getItem("mt-motion") === "reduce") d.setAttribute("data-motion", "reduce");
          var ts = localStorage.getItem("mt-text-size");
          if (ts === "s" || ts === "l") d.setAttribute("data-text-size", ts);
        } catch (e) {}
      })();
    </script>
    <title>{resolvedTitle}</title>
    <meta name="description" content={resolvedDescription} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body class="flex min-h-dvh flex-col">
    <a href="#main" class="skip-link">Skip to content</a>

    <header class="border-b border-hairline">
      <div class="mx-auto flex max-w-[var(--measure-content)] flex-wrap items-center gap-x-6 gap-y-3 px-4 py-4">
        <a href={base} class="shrink-0" aria-label={logoLabel}>
          <img src="/logo-wide.svg" alt="MetroTrack" height="28" class="h-7 w-auto" />
        </a>
        <Nav metro={metro} here={here} />
        <div class="ml-auto"><Toolbar /></div>
      </div>
    </header>

    <main id="main" class="mx-auto w-full max-w-[var(--measure-content)] flex-1 px-4 py-8">
      <slot />
    </main>

    <Footer metro={metro} />
  </body>
</html>
