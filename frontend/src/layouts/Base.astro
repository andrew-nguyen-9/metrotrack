---
import "../styles/globals.css";
import { type Metro, defaultMetro } from "../lib/metros";

interface Props {
  title?: string;
  description?: string;
  metro?: Metro;
}

// Every page lives under a metro now; fall back to the default for safety.
const { metro = defaultMetro(), title, description } = Astro.props;

const resolvedTitle = title ?? `MetroTrack — ${metro.region} Transit Tracker`;
const resolvedDescription =
  description ??
  `A neutral, public accountability tracker for ${metro.region} transit: funding, a usage map against population and jobs, hiring, and a job-access score.`;

const base = `/${metro.slug}`;
// Nav is built from the active metro so islands + links stay generic per metro [B7a].
const nav = [
  { href: base, label: "Overview" },
  { href: `${base}/map`, label: "Map" },
  { href: `${base}/funding`, label: "Funding" },
  { href: `${base}/hiring`, label: "Hiring" },
  { href: `${base}/job-access`, label: "Job access" },
];
const here = Astro.url.pathname.replace(/\/$/, "");

const ogImage = new URL("/og.png", Astro.site).href;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{resolvedTitle}</title>
    <meta name="description" content={resolvedDescription} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body class="min-h-dvh flex flex-col">
    <header class="border-b border-hairline">
      <div class="mx-auto max-w-6xl px-4 py-4 flex flex-wrap items-center gap-x-6 gap-y-3">
        <a href={base} class="shrink-0" aria-label={`MetroTrack ${metro.name} home`}>
          <img src="/logo-wide.svg" alt={`MetroTrack ${metro.name}`} height="28" class="h-7 w-auto" />
        </a>
        <nav aria-label="Primary" class="flex flex-wrap gap-x-4 gap-y-1 text-sm">
          {nav.map((item) => {
            const active = here === item.href.replace(/\/$/, "");
            return (
              <a
                href={item.href}
                aria-current={active ? "page" : undefined}
                class={active ? "text-text" : "text-text-muted hover:text-text"}
              >
                {item.label}
              </a>
            );
          })}
        </nav>
      </div>
    </header>

    <main class="mx-auto w-full max-w-6xl flex-1 px-4 py-8">
      <slot />
    </main>

    <footer class="border-t border-hairline text-text-muted">
      <div class="mx-auto max-w-6xl px-4 py-6 text-sm">
        <p>
          MetroTrack — independent, non-affiliated. Data from CTA, Pace, Metra (GTFS),
          the Chicago Data Portal, and the U.S. Census. Map data ©
          <a class="underline" href="https://www.openstreetmap.org/copyright"
            >OpenStreetMap</a
          > contributors.
        </p>
      </div>
    </footer>
  </body>
</html>
