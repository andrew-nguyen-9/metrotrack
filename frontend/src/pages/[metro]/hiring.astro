---
import Base from "../../layouts/Base.astro";
import VacancyChart from "../../components/VacancyChart.tsx";
import { type Metro, metroPaths, hiringData } from "../../lib/metros";
import {
  authorityLabel, authorities, rowsFor, type HiringData,
} from "../../lib/hiring";

export const getStaticPaths = metroPaths;

const { metro } = Astro.props as { metro: Metro };
const data = hiringData(metro.slug) as HiringData;
const auths = authorities(data.rows);
---

<Base metro={metro} title={`Hiring — MetroTrack ${metro.name}`}>
  <section class="max-w-2xl">
    <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight">
      Who's hiring, tracked weekly
    </h1>
    <p class="mt-4 text-text-muted text-lg">
      Open job postings at CTA, Metra, and Pace, snapshotted every week. The trend is
      the point — it thickens as the weeks accumulate.
    </p>
  </section>

  <section class="mt-10" aria-labelledby="chart-heading">
    <h2 id="chart-heading" class="text-xl font-medium">Open postings over time</h2>
    <p class="mt-1 text-sm text-text-muted max-w-3xl">
      Each line is one service board's count of currently-listed job postings, taken
      weekly from the authority's own careers site. This is <strong>hiring activity</strong>,
      not a vacancy rate or an understaffing measure — counts aren't normalized by
      budgeted headcount, and a high count can mean growth as easily as churn. The
      rider-felt service-shortfall headline (scheduled vs. delivered service) lands
      once realtime delivery data is ingested.
    </p>

    <div class="mt-4 rounded-lg border border-hairline bg-surface p-4">
      <VacancyChart client:visible rows={data.rows} authorities={auths} metro={metro.name} />
    </div>

    <p class="mt-2 text-xs text-text-muted">
      Source: {data.source.label}. {data.source.note}
      {data.asOf && <> Latest snapshot: <span class="tabular">{data.asOf}</span>.</>}
    </p>

    <!-- Accessible, no-JS fallback: the chart is an enhancement; this table carries
         the same numbers, with each authority named (not color-coded). -->
    <details class="mt-4 rounded-lg border border-hairline bg-surface" open>
      <summary class="cursor-pointer px-4 py-3 font-medium">
        Open-postings data (table)
      </summary>
      <div class="overflow-x-auto px-4 pb-4">
        <table class="w-full text-left text-sm">
          <caption class="sr-only">Weekly open job postings by service board and snapshot date</caption>
          <thead>
            <tr class="border-b border-hairline text-text-muted">
              <th scope="col" class="py-2 pr-4 font-medium">Service board</th>
              <th scope="col" class="py-2 pr-4 font-medium">Snapshot date</th>
              <th scope="col" class="py-2 font-medium">Open postings</th>
            </tr>
          </thead>
          <tbody>
            {auths.map((a) => (
              <>
                {rowsFor(data.rows, a).map((r, i) => (
                  <tr class="border-b border-hairline/40">
                    <td class="py-1.5 pr-4">{i === 0 ? authorityLabel(a) : ""}</td>
                    <td class="py-1.5 pr-4 tabular">{r.as_of}</td>
                    <td class="py-1.5 tabular">{r.open_postings.toLocaleString()}</td>
                  </tr>
                ))}
              </>
            ))}
          </tbody>
        </table>
      </div>
      <p class="px-4 pb-4 text-xs text-text-muted">
        Counts are postings listed on each authority's careers site (CTA via Taleo,
        Metra via Cadient, Pace via Oracle Recruiting). Methodology + receipts:
        <span class="tabular">data/bronze/hiring/SOURCE.md</span>.
      </p>
    </details>
  </section>
</Base>
