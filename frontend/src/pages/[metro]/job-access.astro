---
import Base from "../../layouts/Base.astro";
import { type Metro, metroPaths, accessData } from "../../lib/metros";

export const getStaticPaths = metroPaths;

const { metro } = Astro.props as { metro: Metro };

// The job-access score is the signature pillar, but its data export does not exist
// yet — the access gold lives in the DB and isn't surfaced to the frontend until the
// access pillar lands (v2.5 [L*]). Degrade gracefully: render an honest placeholder,
// never fabricate numbers, and log the gap at build so it's visible in CI.
const access = accessData(metro.slug);
const hasAccess = access != null;
if (!hasAccess) {
  console.warn(
    `[job-access] no access export for metro '${metro.slug}' — rendering placeholder (access pillar pending, v2.5).`,
  );
}
---

<Base metro={metro} title={`Job access — MetroTrack ${metro.name}`}>
  <section class="max-w-2xl">
    <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight">
      Job access
    </h1>
    <p class="mt-4 text-text-muted text-lg">
      The signature score: how many jobs a typical resident can reach by transit and a
      short walk — the clearest measure of whether the network actually connects people
      to work.
    </p>
  </section>

  <section class="mt-10">
    <div class="rounded-lg border border-hairline bg-surface p-6">
      <h2 class="text-lg font-medium">Job-access score arrives with the access pillar</h2>
      <p class="mt-2 max-w-2xl text-sm text-text-muted">
        We don't have a published job-access export for {metro.name} yet, so there is
        nothing to show here — and we won't invent a number. The score is computed from
        Census LODES jobs and openrouteservice walk isochrones (see
        <span class="tabular"> ADR-003</span>); it lands once the access pillar is wired
        through to the frontend. Until then, the
        <a class="underline" href={`/${metro.slug}/map`}>map's job-access overlay</a>
        shows the underlying ½-mi-walk reach per H3 hex cell.
      </p>
    </div>
  </section>
</Base>
