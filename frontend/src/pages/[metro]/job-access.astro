---
import Base from "@/layouts/Base.astro";
import AccessMap from "@/components/AccessMap.tsx";
import Stack from "@/components/kit/Stack.astro";
import Card from "@/components/kit/Card.astro";
import Stat from "@/components/kit/Stat.astro";
import StatBand from "@/components/kit/StatBand.astro";
import Callout from "@/components/kit/Callout.astro";
import SourceTag from "@/components/kit/SourceTag.astro";
import DataState from "@/components/kit/DataState.astro";
import { type Metro, metroPaths, transitData, pmtilesUrl } from "@/lib/metros";
import { type TransitData, type HexCell } from "@/lib/transit";

export const getStaticPaths = metroPaths;

const { metro } = Astro.props as { metro: Metro };
const data = transitData(metro.slug) as TransitData;
const hex = data.hex;
const hasData = hex.count > 0 && hex.topAccess.length > 0;

// The signature score is `jobs_reachable_walk` per H3 hex (transform/models/gold/
// gold_hex_access.sql), exported into transit.json by pipeline/tiles.py — the same
// artifact the map page reads. The strongest hex is the headline figure; the full
// distribution is the choropleth. topAccess is pre-sorted desc by the exporter.
const top = hasData ? hex.topAccess[0] : null;

const METHODOLOGY = "https://github.com/andrew-nguyen-9/metrotrack/blob/main/docs/modeling/ACCESS_SCORE.md";
const LODES = "https://lehd.ces.census.gov/data/lodes/LODES8/";
---

<Base metro={metro} title={`Job access — MetroTrack ${metro.name}`}>
  <Stack gap="2xl">
    <Stack gap="sm" class="max-w-[var(--measure)]">
      <h1 class="text-[length:var(--text-3xl)] font-semibold leading-[var(--leading-tight)] tracking-tight">
        How many jobs you can reach
      </h1>
      <p class="text-[length:var(--text-md)] text-text-muted">
        The signature score: for each area, the number of jobs within a short walk —
        the clearest single measure of whether the network actually connects people to
        work. Darker cells reach more jobs.
      </p>
    </Stack>

    {hasData && top && (
      <StatBand aria-label="Job-access headline figures">
        <Card>
          <Stat
            value={top.access!.toLocaleString()}
            label="Jobs reachable — most-connected area"
            hint="highest job-access score of any hex cell"
          />
        </Card>
        <Card>
          <Stat
            value={hex.count.toLocaleString()}
            label="Hex cells scored"
            hint="H3 cells across Cook County"
          />
        </Card>
      </StatBand>
    )}

    <Callout tone="warning" title="This is a straight-line estimate">
      {/* ponytail: ORS_API_KEY absent from deploy → the published ambient score is a
          great-circle ½-mi walkshed (sum of jobs whose hex centroid is within ½ mi),
          not a street-network isochrone. It over-counts where water/rail/highways
          break the grid. ORS network isochrones (ADR-003) refine it once the nightly
          batch precompute is wired — see the methodology's open questions. */}
      Reach is measured as a <strong>straight-line (great-circle) ½-mile walkshed</strong>:
      the jobs in every area whose center sits within half a mile. It does not yet route
      around rivers, rail yards, or highways, so it can overstate reach where the street
      grid breaks. Street-network walk isochrones (openrouteservice, ADR-003) refine this
      once the nightly precompute is configured — no synthetic number is published in the
      meantime.
    </Callout>

    <Stack gap="md" as="section" aria-labelledby="map-heading">
      <h2 id="map-heading" class="text-[length:var(--text-lg)] font-medium">
        Job access across {metro.name}
      </h2>

      {hasData ? (
        <Card>
          <div class="h-[60vh] min-h-80 w-full overflow-hidden rounded-lg">
            <AccessMap
              client:only="react"
              pmtilesUrl={pmtilesUrl(metro.slug)}
              bbox={metro.bbox}
              hex={hex}
              metro={metro.name}
            />
          </div>
        </Card>
      ) : (
        <DataState
          state="coming"
          title="No job-access scores yet"
          message="The choropleth renders once the gold hex-access model is built for this metro."
        />
      )}

      <SourceTag
        source="U.S. Census LEHD LODES8 (2022, workplace jobs)"
        id="access"
        href={LODES}
        asOf="LODES8, 2022"
        note="Jobs reachable within a ½-mi straight-line walk, aggregated to H3 hex cells over Cook County"
      />

      <p class="text-sm text-text-muted">
        <a class="underline hover:text-text" href={METHODOLOGY} target="_blank" rel="noopener noreferrer">
          Read the full methodology (ACCESS_SCORE.md)
        </a> — definition, cutoffs, walk radius, and the openrouteservice roadmap.
      </p>

      <!-- Accessible, no-JS fallback: the choropleth is an enhancement; this table
           carries the same scores, ranked, with the strongest areas named by H3 index
           (not color-coded). -->
      <details class="rounded-lg border border-hairline bg-surface" open={hasData}>
        <summary class="cursor-pointer px-4 py-3 font-medium">
          Most-connected areas (table)
        </summary>
        <div class="overflow-x-auto px-4 pb-4">
          <table class="w-full text-left text-sm">
            <caption class="sr-only">Top areas by jobs reachable within a half-mile walk</caption>
            <thead>
              <tr class="border-b border-hairline text-text-muted">
                <th scope="col" class="py-2 pr-4 font-medium">Rank</th>
                <th scope="col" class="py-2 pr-4 font-medium">Hex cell (H3)</th>
                <th scope="col" class="py-2 pr-4 font-medium">Jobs reachable</th>
                <th scope="col" class="py-2 pr-4 font-medium">Jobs based here</th>
                <th scope="col" class="py-2 font-medium">Population</th>
              </tr>
            </thead>
            <tbody>
              {hex.topAccess.map((c: HexCell, i: number) => (
                <tr class="border-b border-hairline/40">
                  <td class="py-1.5 pr-4 tabular">{i + 1}</td>
                  <td class="py-1.5 pr-4 font-mono text-xs text-text-muted">{c.h3}</td>
                  <td class="py-1.5 pr-4 tabular">{c.access?.toLocaleString() ?? "—"}</td>
                  <td class="py-1.5 pr-4 tabular">{c.jobs.toLocaleString()}</td>
                  <td class="py-1.5 tabular">{c.population.toLocaleString()}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="px-4 pb-4 text-xs text-text-muted">
          Jobs: U.S. Census LEHD LODES8 (2022, workplace). Job access: jobs reachable
          within a ½-mi straight-line walk (openrouteservice network isochrones when
          configured — ADR-003). Aggregated to H3 hex cells over Cook County.
        </p>
      </details>
    </Stack>
  </Stack>
</Base>
