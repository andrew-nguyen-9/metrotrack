---
import Base from "../../layouts/Base.astro";
import FundingChart from "../../components/FundingChart.tsx";
import { type Metro, metroPaths, fundingData } from "../../lib/metros";
import {
  authorityLabel, fmtUSD, fmtPct, authorities, rowsFor,
  RTA_KIND_LABELS, SERIES_LABELS, type FundingData,
} from "../../lib/funding";

export const getStaticPaths = metroPaths;

const { metro } = Astro.props as { metro: Metro };
const data = fundingData(metro.slug) as FundingData;
const auths = authorities(data.rows);
const sources = data.sources;
---

<Base metro={metro} title={`Funding — MetroTrack ${metro.name}`}>
  <section class="max-w-2xl">
    <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight">
      Where the money goes
    </h1>
    <p class="mt-4 text-text-muted text-lg">
      Operating spending for the three service boards — audited actuals against the
      RTA's adopted budget and forward plan. Every figure shows its source and&nbsp;<span class="tabular">as-of</span> date.
    </p>
  </section>

  <section class="mt-10" aria-labelledby="chart-heading">
    <h2 id="chart-heading" class="text-xl font-medium">
      Operating budget vs. actual, by service board
    </h2>
    <p class="mt-1 text-sm text-text-muted max-w-3xl">
      <strong>Actual</strong> = audited operating expense (FTA National Transit
      Database). <strong>RTA budget / plan</strong> = the RTA's adopted figure for
      each year, labeled by its true nature (actual, estimate, adopted budget, or
      forward plan). The two series come from different sources defined slightly
      differently, so they are shown side by side, never merged — for CTA and Metra
      they track within ~2%; Pace's gap is larger because its figure folds in Regional
      ADA Paratransit. The 2026–2027 plan years show the projected{" "}
      <a class="underline" href={sources.rta.url} target="_blank" rel="noopener">fiscal-cliff</a>{" "}
      trajectory.
    </p>

    <div class="mt-4 rounded-lg border border-hairline bg-surface p-4">
      <FundingChart client:visible rows={data.rows} authorities={auths} metro={metro.name} />
    </div>

    <p class="mt-2 text-xs text-text-muted">
      Sources: <a class="underline" href={sources.actual.url} target="_blank" rel="noopener">{sources.actual.label}</a>
      ({sources.actual.asOf}) · <a class="underline" href={sources.rta.url} target="_blank" rel="noopener">{sources.rta.label}</a>
      ({sources.rta.asOf}).
    </p>

    <!-- Accessible, no-JS fallback: the chart is an enhancement; this table carries
         the same numbers with the series named (not color-coded). -->
    <details class="mt-4 rounded-lg border border-hairline bg-surface" open>
      <summary class="cursor-pointer px-4 py-3 font-medium">
        Budget &amp; actual data (table)
      </summary>
      <div class="overflow-x-auto px-4 pb-4">
        <table class="w-full text-left text-sm">
          <caption class="sr-only">
            Audited actual operating expense and RTA budget/plan figures by service board and fiscal year
          </caption>
          <thead>
            <tr class="border-b border-hairline text-text-muted">
              <th scope="col" class="py-2 pr-4 font-medium">Fiscal year</th>
              <th scope="col" class="py-2 pr-4 font-medium">{SERIES_LABELS.actual}</th>
              <th scope="col" class="py-2 pr-4 font-medium">{SERIES_LABELS.rta}</th>
              <th scope="col" class="py-2 font-medium">Farebox recovery</th>
            </tr>
          </thead>
          <tbody>
            {auths.map((a) => (
              <>
                <tr class="border-b border-hairline/60">
                  <th scope="rowgroup" colspan="4" class="pt-4 pb-1 text-text">
                    {authorityLabel(a)}
                  </th>
                </tr>
                {rowsFor(data.rows, a).map((r) => (
                  <tr class="border-b border-hairline/40">
                    <td class="py-1.5 pr-4 tabular">{r.fiscal_year}</td>
                    <td class="py-1.5 pr-4 tabular">
                      {r.actual_audited == null ? "—" : fmtUSD(r.actual_audited)}
                    </td>
                    <td class="py-1.5 pr-4 tabular">
                      {r.rta_amount == null ? "—" : fmtUSD(r.rta_amount)}
                      {r.rta_kind && (
                        <span class="ml-1 text-text-muted font-normal">
                          ({RTA_KIND_LABELS[r.rta_kind] ?? r.rta_kind})
                        </span>
                      )}
                    </td>
                    <td class="py-1.5 tabular">
                      {r.farebox_recovery == null ? "—" : fmtPct(r.farebox_recovery)}
                    </td>
                  </tr>
                ))}
              </>
            ))}
          </tbody>
        </table>
      </div>
      <p class="px-4 pb-4 text-xs text-text-muted">
        Pace includes Regional ADA Paratransit, which Pace operates. Farebox recovery
        = fare revenue ÷ audited operating expense (FTA NTD).
      </p>
    </details>
  </section>
</Base>
