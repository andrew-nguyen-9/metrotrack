---
import Base from "../../layouts/Base.astro";
import { type Metro, metroPaths } from "../../lib/metros";

export const getStaticPaths = metroPaths;

const { metro } = Astro.props as { metro: Metro };
const base = `/${metro.slug}`;

// Three pillars (docs/overview/VISION.md). Numbers are intentionally absent until
// the pipelines that source them land — honest by construction.
const pillars = [
  { name: "Funding", body: "NITA / CTA / Pace / Metra budgets vs. actuals — where the money goes.", href: `${base}/funding` },
  { name: "Mapping", body: "Bus & rail usage against population, jobs, and destinations.", href: `${base}/map` },
  { name: "Hiring", body: "Open reqs and understaffing tracked weekly into a vacancy trend.", href: `${base}/hiring` },
];
---

<Base metro={metro} title={`MetroTrack — ${metro.region} Transit Tracker`}>
  <section class="max-w-2xl">
    <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight">
      {metro.region} transit, measured.
    </h1>
    <p class="mt-4 text-text-muted text-lg">
      A neutral, public accountability tracker — funding, usage, hiring, and a
      job-access score — built on open data. Every figure shows its source
      and&nbsp;<span class="tabular">as-of</span> date.
    </p>
  </section>

  <ul class="mt-10 grid gap-4 sm:grid-cols-3">
    {pillars.map((p) => (
      <li class="rounded-lg border border-hairline bg-surface p-5">
        <h2 class="font-medium">
          <a class="hover:underline" href={p.href}>{p.name}</a>
        </h2>
        <p class="mt-2 text-sm text-text-muted">{p.body}</p>
      </li>
    ))}
  </ul>

  <section class="mt-12">
    <h2 class="text-xl font-medium">Routes, stops &amp; the people they serve</h2>
    <p class="mt-1 max-w-3xl text-sm text-text-muted">
      Explore CTA, Pace, and Metra routes and stops on an interactive map, over a hex
      overlay of jobs, population, and a job-access score across Cook County.
    </p>
    <p class="mt-4">
      <a
        href={`${base}/map`}
        class="inline-block rounded-md border border-hairline bg-surface px-4 py-2 text-sm font-medium hover:text-text"
      >
        Open the map →
      </a>
    </p>
  </section>
</Base>
