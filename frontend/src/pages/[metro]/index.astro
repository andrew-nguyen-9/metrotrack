---
// Region homepage — the per-metro landing (E2), rebuilt on the kit: hero + a card
// deck linking to that metro's pages. Generic per metro (driven by the Metro prop),
// so every live metro gets the same shell.
import Base from "@/layouts/Base.astro";
import Stack from "@/components/kit/Stack.astro";
import Grid from "@/components/kit/Grid.astro";
import Card from "@/components/kit/Card.astro";
import { type Metro, metroPaths } from "@/lib/metros";

export const getStaticPaths = metroPaths;

const { metro } = Astro.props as { metro: Metro };
const base = `/${metro.slug}`;

// One card per page of this metro. Numbers stay on the pages themselves (sourced);
// this landing is pure navigation, so it needs no figures.
const sections = [
  { name: "Funding", body: "NITA / CTA / Pace / Metra budgets vs. actuals — where the money goes.", href: `${base}/funding` },
  { name: "Map", body: "Bus & rail usage against population, jobs, and destinations.", href: `${base}/map` },
  { name: "Hiring", body: "Open reqs and understaffing tracked weekly into a vacancy trend.", href: `${base}/hiring` },
  { name: "Job access", body: "The signature score: jobs reachable by transit, by neighborhood.", href: `${base}/job-access` },
];
---

<Base metro={metro} title={`MetroTrack — ${metro.region} Transit Tracker`}>
  <Stack gap="2xl">
    <section class="max-w-[60ch]">
      <h1 class="text-[length:var(--text-3xl)] font-semibold tracking-tight leading-[var(--leading-tight)]">
        {metro.region} transit, measured.
      </h1>
      <p class="mt-4 text-[length:var(--text-lg)] text-text-muted">
        A neutral, public accountability tracker — funding, usage, hiring, and a
        job-access score — built on open data. Every figure shows its source
        and&nbsp;<span class="tabular">as-of</span> date.
      </p>
    </section>

    <section>
      <Stack gap="md">
        <h2 class="text-[length:var(--text-xl)] font-medium">Explore {metro.name}</h2>
        <Grid min="16rem" gap="md" as="ul">
          {sections.map((s) => (
            <li>
              <Card title={s.name} href={s.href}>{s.body}</Card>
            </li>
          ))}
        </Grid>
      </Stack>
    </section>
  </Stack>
</Base>
