---
// Global primary nav — built from the active metro so links stay generic per
// metro [B7a]. Keep the nav-from-metro pattern: pages pass their Metro.
import type { Metro } from "@/lib/metros";

interface Props {
  metro: Metro;
  here: string; // current pathname, trailing slash stripped
}
const { metro, here } = Astro.props;
const base = `/${metro.slug}`;
const items = [
  { href: base, label: "Overview" },
  { href: `${base}/map`, label: "Map" },
  { href: `${base}/funding`, label: "Funding" },
  { href: `${base}/ridership`, label: "Ridership" },
  { href: `${base}/hiring`, label: "Hiring" },
  { href: `${base}/job-access`, label: "Job access" },
];
---

<nav aria-label="Primary" class="flex flex-wrap gap-x-4 gap-y-1 text-sm">
  {items.map((item) => {
    const active = here === item.href.replace(/\/$/, "");
    return (
      <a
        href={item.href}
        aria-current={active ? "page" : undefined}
        class={active ? "text-text" : "text-text-muted hover:text-text"}
      >
        {item.label}
      </a>
    );
  })}
</nav>
