# MetroTrack — environment template. Copy to .env and fill real values.
#   cp .env.example .env
# .env is gitignored; this file is committed and must contain NO secrets.
#
# Two Supabase projects, pooled for 10GB storage (5GB each), split by data
# domain. PROJECT_A and PROJECT_B are both live. Decide what lives where in
# docs/architecture/DATA_SOURCES.md.
#
# Key types (Supabase's current naming; legacy names in parens):
#   *_URL              project REST/Postgres URL          — public
#   *_PUBLISHABLE_KEY  client-side key (legacy: anon)     — public, safe in browser bundle
#   *_SECRET_KEY       server-side key (legacy: service_role) — SECRET, never in client bundle
#
# Astro/Vercel exposes only vars prefixed PUBLIC_ to the browser. Service keys
# stay unprefixed so they never reach the client. RLS on every table regardless.

# ── Supabase project A ────────────────────────────────────────────────
PUBLIC_SUPABASE_A_URL=https://your-project-a.supabase.co
PUBLIC_SUPABASE_A_PUBLISHABLE_KEY=
SUPABASE_A_SECRET_KEY=
# Direct Postgres connection (pipeline / dbt). Pooler URL from the dashboard.
SUPABASE_A_DB_URL=postgresql://postgres:[PASSWORD]@your-project-a.pooler.supabase.com:5432/postgres

# ── Supabase project B ────────────────────────────────────────────────
PUBLIC_SUPABASE_B_URL=https://your-project-b.supabase.co
PUBLIC_SUPABASE_B_PUBLISHABLE_KEY=
SUPABASE_B_SECRET_KEY=
SUPABASE_B_DB_URL=postgresql://postgres:[PASSWORD]@your-project-b.pooler.supabase.com:5432/postgres
